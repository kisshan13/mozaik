{
	"name": "@mozaik-ai/core",
	"version": "2.10.0",
	"description": "A TypeScript library for building AI agents",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"typesVersions": {
		"*": {
			"core": [
				"dist/core/index.d.ts"
			],
			"providers/openai": [
				"dist/providers/openai/index.d.ts"
			]
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jigjoy-ai/mozaik.git"
	},
	"author": "Miodrag Vilotijević",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rimraf dist",
		"format": "prettier --write \"src/**/*.{ts,tsx}\"",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"ai-agent",
		"agentic-ai",
		"agent-framework",
		"ai-workflow",
		"ai-orchestration",
		"ai-agents",
		"ai-developer-tools",
		"ai-infrastructure",
		"autonomous-agent",
		"multi-agent-system",
		"openai",
		"llm"
	],
	"license": "MIT",
	"devDependencies": {
		"prettier": "^3.7.4",
		"rimraf": "^5.0.5",
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.74.0",
		"dotenv": "^17.4.1",
		"openai": "^6.33.0",
		"zod": "^4.3.6"
	}
}
